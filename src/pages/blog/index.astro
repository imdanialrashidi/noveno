---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const posts = [
  {
    title: 'چرا یک سایت زیبا به تنهایی کافی نیست؟',
    description: 'طراحی زیبا مهم است، ولی بدون مسیر جذب مشتری مشخص، فقط یک دکوراسیون گران‌قیمت است.',
    href: '/blog/why-a-beautiful-website-is-not-enough',
    date: '۱۴۰۴/۰۳/۱۵',
    readTime: '۵ دقیقه',
  },
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'بلاگ نوونو',
  description: 'مقاله‌هایی درباره جذب مشتری، طراحی سایت و بهبود مسیر فروش برای کسب‌وکارهای کوچک.',
  url: 'https://noveno.ir/blog',
};
---

<BaseLayout
  title="بلاگ"
  description="مقاله‌هایی درباره جذب مشتری، طراحی سایت و بهبود مسیر فروش برای کسب‌وکارهای کوچک."
  structuredData={structuredData}
>
  <section class="section-padding bg-gradient-to-b from-lavender-100 to-surface-50">
    <div class="container-page">
      <Breadcrumbs items={[{ label: 'بلاگ' }]} />

      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-3xl font-bold text-neutral-800 sm:text-4xl">
          بلاگ
        </h1>
        <p class="mt-4 text-base leading-7 text-neutral-600 sm:text-lg">
          مقاله‌هایی درباره جذب مشتری، طراحی سایت و بهبود مسیر فروش.
        </p>
      </div>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-page">
      <div class="mx-auto max-w-3xl space-y-6">
        {posts.map((post) => (
          <a
            href={post.href}
            class="group block rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm transition-all duration-200 hover:border-brand-300 hover:shadow-md"
          >
            <div class="flex items-center gap-3 text-xs text-neutral-400">
              <time>{post.date}</time>
              <span>·</span>
              <span>{post.readTime} مطالعه</span>
            </div>
            <h2 class="mt-3 text-lg font-semibold text-neutral-800 group-hover:text-brand-600 transition-colors">
              {post.title}
            </h2>
            <p class="mt-2 text-sm leading-6 text-neutral-500">{post.description}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-brand-600 group-hover:gap-2 transition-all">
              ادامه مطلب
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
