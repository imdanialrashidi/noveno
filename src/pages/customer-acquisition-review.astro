---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ReviewForm from '../components/ReviewForm.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'بررسی مسیر جذب مشتری',
  provider: {
    '@type': 'Organization',
    name: 'نوونو',
  },
  description: 'بررسی ساده و رایگان مسیر جذب مشتری فعلی کسب‌وکار شما با یک پیشنهاد عملی برای بهبود.',
};
---

<BaseLayout
  title="درخواست بررسی مسیر جذب مشتری"
  description="مسیر جذب مشتری کسب‌وکار خود را بررسی کنید. یک پیشنهاد عملی و رایگان برای بهبود مسیر تبدیل بازدیدکننده به مشتری."
  structuredData={structuredData}
>
  <section class="section-padding bg-gradient-to-b from-lavender-100 to-surface-50">
    <div class="container-page">
      <Breadcrumbs items={[{ label: 'درخواست بررسی مسیر جذب' }]} />

      <div class="mx-auto max-w-3xl">
        <div class="text-center">
          <p class="mb-3 text-sm font-medium text-brand-600">رایگان و بدون تعهد</p>
          <h1 class="text-3xl font-bold text-neutral-800 sm:text-4xl text-balance">
            مسیر جذب مشتری خود را بررسی کنید
          </h1>
          <p class="mt-4 text-base leading-7 text-neutral-600 sm:text-lg">
            اگر نمی‌دانید چرا بازدیدکننده‌های سایت یا پیج شما به مشتری تبدیل نمی‌شوند، این بررسی کمک می‌کند مشکل را پیدا کنید.
          </p>
        </div>

        <!-- What You Get -->
        <div class="mt-10 grid gap-4 sm:grid-cols-3">
          <div class="rounded-xl bg-white p-5 text-center shadow-sm">
            <div class="mx-auto flex h-10 w-10 items-center justify-center rounded-lg bg-brand-50 text-brand-600">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
            </div>
            <h3 class="mt-3 text-sm font-semibold text-neutral-800">بررسی وضعیت فعلی</h3>
            <p class="mt-1 text-xs text-neutral-500">مسیر جذب مشتری فعلی شما بررسی می‌شود.</p>
          </div>
          <div class="rounded-xl bg-white p-5 text-center shadow-sm">
            <div class="mx-auto flex h-10 w-10 items-center justify-center rounded-lg bg-brand-50 text-brand-600">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <h3 class="mt-3 text-sm font-semibold text-neutral-800">شناسایی مشکلات</h3>
            <p class="mt-1 text-xs text-neutral-500">موانع اصلی تبدیل بازدیدکننده مشخص می‌شوند.</p>
          </div>
          <div class="rounded-xl bg-white p-5 text-center shadow-sm">
            <div class="mx-auto flex h-10 w-10 items-center justify-center rounded-lg bg-brand-50 text-brand-600">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            </div>
            <h3 class="mt-3 text-sm font-semibold text-neutral-800">پیشنهاد عملی</h3>
            <p class="mt-1 text-xs text-neutral-500">یک پیشنهاد ساده و عملی برای بهبود دریافت می‌کنید.</p>
          </div>
        </div>

        <!-- Important Notes -->
        <div class="mt-8 space-y-3">
          <div class="flex items-start gap-3 rounded-xl border border-neutral-200 bg-white p-4">
            <svg class="h-5 w-5 shrink-0 text-brand-600 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <div>
              <h3 class="text-sm font-semibold text-neutral-800">این بررسی به معنای فروش تضمینی نیست</h3>
              <p class="mt-1 text-xs text-neutral-500">خروجی بررسی یک پیشنهاد عملی است. نتیجه نهایی به عوامل متعددی بستگی دارد.</p>
            </div>
          </div>
          <div class="flex items-start gap-3 rounded-xl border border-neutral-200 bg-white p-4">
            <svg class="h-5 w-5 shrink-0 text-brand-600 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <div>
              <h3 class="text-sm font-semibold text-neutral-800">بررسی رایگان و بدون تعهد است</h3>
              <p class="mt-1 text-xs text-neutral-500">هیچ هزینه یا تعهدی برای دریافت این بررسی وجود ندارد.</p>
            </div>
          </div>
        </div>

        <!-- Form -->
        <div class="mt-10 rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm sm:p-8">
          <ReviewForm />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
