const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'صنایع مناسب برای نوونو',
  description: 'کسب‌وکارهایی که نوونو برای آن‌ها طراحی شده: کلینیک‌ها، آموزشگاه‌ها، سالن‌های زیبایی، مشاوران املاک و غیره.',
  url: 'https://noveno.ir/industries',
};
---

<BaseLayout
  title="صنایع مناسب"
  description="نوونو برای کسب‌وکارهایی طراحی شده که هر مشتری جدید ارزش اقتصادی واقعی دارد. صنایع مناسب و ویژگی‌های آن‌ها را بشناسید."
  structuredData={structuredData}
>
  <section class="section-padding bg-gradient-to-b from-lavender-100 to-surface-50">
    <div class="container-page">
      <Breadcrumbs items={[{ label: 'صنایع مناسب' }]} />

      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-3xl font-bold text-neutral-800 sm:text-4xl text-balance">
          کسب‌وکارهایی که برای آن‌ها طراحی شده‌ایم
        </h1>
        <p class="mt-4 text-base leading-7 text-neutral-600 sm:text-lg">
          نوونو برای کسب‌وکارهایی مناسب است که از هر مشتری جدید ارزش اقتصادی واقعی می‌گیرند و به راه‌حل ساده، قابل فهم و قابل اجرا نیاز دارند. مشتری هدف، کسب‌وکاری است که محصول یا خدمت مشخصی دارد و می‌خواهد مسیر جذب مشتری‌اش منظم‌تر و قابل پیگیری‌تر شود.
        </p>
      </div>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-page">
      <div class="mx-auto grid max-w-5xl gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {industries.map((industry) => (
          <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-lavender-200 text-brand-600">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={industry.icon} />
              </svg>
            </div>
            <h2 class="mt-4 text-lg font-semibold text-neutral-800">{industry.name}</h2>
            <p class="mt-2 text-sm leading-6 text-neutral-500">{industry.description}</p>
            <ul class="mt-4 space-y-1.5">
              {industry.details.map((detail) => (
                <li class="flex items-center gap-2 text-sm text-neutral-600">
                  <svg class="h-4 w-4 shrink-0 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {detail}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-surface-50">
    <div class="container-page">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-2xl font-bold text-neutral-800 sm:text-3xl">
          کسب‌وکار شما در لیست نیست؟
        </h2>
        <p class="mt-3 text-base text-neutral-600">
          اگر کسب‌وکار شما در لیست بالا نیست ولی فکر می‌کنید نوونو می‌تواند کمک کند، با ما تماس بگیرید. بررسی اولیه رایگان است.
        </p>
        <div class="mt-6">
          <a href="/customer-acquisition-review" class="inline-flex items-center gap-2 rounded-xl bg-brand-600 px-6 py-3 text-sm font-medium text-white hover:bg-brand-700 transition-colors">
            درخواست بررسی مسیر جذب
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
