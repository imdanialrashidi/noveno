---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTAButton from '../components/CTAButton.astro';

const portfolioItems = [
  {
    id: 'mobilekhorsandi',
    title: 'موبایل خرسندی',
    url: 'https://mobilekhorsandi.ir/',
    coverImage: '/images/portfolio/mobilekhorsandi.ir/cover.webp',
    type: 'فروشگاه اینترنتی موبایل و لوازم جانبی',
    category: 'فروشگاه آنلاین',
    shortDescription: 'طراحی و پیاده‌سازی فروشگاه اینترنتی برای عرضه موبایل، لوازم جانبی، قطعات و گجت‌های کاربردی با مسیر خرید و دسته‌بندی محصول.',
    tags: ['فروشگاه آنلاین', 'موبایل و لوازم جانبی', 'دسته‌بندی محصول', 'مسیر خرید', 'وردپرس'],
    alt: 'نمایی از وب‌سایت فروشگاهی موبایل خرسندی',
    featured: true,
  },
  {
    id: 'elsahamrah',
    title: 'السا همراه',
    url: 'https://elsahamrah.com/',
    coverImage: '/images/portfolio/elsahamrah.com/cover.webp',
    type: 'فروشگاه اینترنتی گوشی، تبلت و ساعت هوشمند',
    category: 'فروشگاه آنلاین',
    shortDescription: 'طراحی فروشگاه اینترنتی برای فروش گوشی، تبلت، ساعت هوشمند و محصولات دیجیتال با تمرکز بر تجربه خرید ساده و قابل اعتماد.',
    tags: ['فروشگاه کالای دیجیتال', 'گوشی و تبلت', 'ساعت هوشمند', 'اعتمادسازی', 'تجربه خرید'],
    alt: 'نمایی از وب‌سایت فروشگاهی السا همراه',
    featured: true,
  },
  {
    id: 'php-ielts-house',
    title: 'خانه آیلتس PHP',
    url: 'https://phpieltshouse.ir/',
    coverImage: '/images/portfolio/phpieltshouse.ir/cover.webp',
    type: 'وب‌سایت آموزشی زبان و آیلتس',
    category: 'سایت آموزشی / خدماتی',
    shortDescription: 'طراحی سایت آموزشی برای معرفی خدمات تخصصی زبان و آیلتس در کرج با تمرکز بر ثبت‌نام، اعتمادسازی و ارتباط سریع با مخاطب.',
    tags: ['سایت آموزشی', 'آیلتس', 'زبان انگلیسی', 'ثبت‌نام', 'خدمات آموزشی'],
    alt: 'نمایی از وب‌سایت آموزشی خانه آیلتس PHP',
    featured: true,
  },
  {
    id: 'isbatab',
    title: 'ایمن صنعت باتاب',
    url: 'https://isbatab.ir/',
    coverImage: '/images/portfolio/isbatab.ir/cover.webp',
    type: 'وب‌سایت شرکتی خدمات ایمنی، آموزش و بازرسی فنی',
    category: 'سایت شرکتی / خدماتی',
    shortDescription: 'طراحی وب‌سایت شرکتی برای معرفی خدمات مشاوره، آموزش، ایمنی و بازرسی فنی با ساختار رسمی و قابل اعتماد.',
    tags: ['سایت شرکتی', 'خدمات ایمنی', 'بازرسی فنی', 'آموزش', 'اعتبارسازی'],
    alt: 'نمایی از وب‌سایت شرکتی ایمن صنعت باتاب',
    featured: true,
  },
  {
    id: 'danial-rashidi',
    title: 'وب‌سایت شخصی دانیال رشیدی',
    url: 'https://imdanialrashidi.github.io/',
    coverImage: '/images/portfolio/imdanialrashidi.github.io/cover.webp',
    type: 'وب‌سایت شخصی و معرفی مهارت‌ها',
    category: 'سایت شخصی / پرتفولیو',
    shortDescription: 'طراحی وب‌سایت شخصی برای معرفی مسیر کاری، مهارت‌ها، علاقه‌مندی‌ها و هویت حرفه‌ای در حوزه وب و سیستم‌های هوش مصنوعی.',
    tags: ['سایت شخصی', 'پرتفولیو', 'هویت حرفه‌ای', 'وب و هوش مصنوعی', 'طراحی سبک'],
    alt: 'نمایی از وب‌سایت شخصی دانیال رشیدی',
    featured: false,
  },
];

const featuredItems = portfolioItems.filter(item => item.featured);
const otherItems = portfolioItems.filter(item => !item.featured);

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'نمونه کارهای نوونو',
  description: 'نمونه‌هایی از وب‌سایت‌ها و سیستم‌هایی که با تمرکز بر معرفی بهتر کسب‌وکار، مسیر اقدام کاربر و حضور حرفه‌ای آنلاین طراحی و اجرا شده‌اند.',
  url: 'https://noveno.ir/portfolio',
};
---

<BaseLayout
  title="نمونه کار"
  description="نمونه‌هایی از وب‌سایت‌ها و سیستم‌هایی که با تمرکز بر معرفی بهتر کسب‌وکار، مسیر اقدام کاربر و حضور حرفه‌ای آنلاین طراحی و اجرا شده‌اند."
  structuredData={structuredData}
>
  <section class="section-padding bg-gradient-to-b from-lavender-100 to-surface-50">
    <div class="container-page">
      <Breadcrumbs items={[{ label: 'نمونه کار' }]} />

      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-3xl font-bold text-neutral-800 sm:text-4xl text-balance">
          نمونه‌کارهای نوونو
        </h1>
        <p class="mt-4 text-base leading-7 text-neutral-600 sm:text-lg">
          چند نمونه از وب‌سایت‌ها و سیستم‌هایی که با تمرکز بر معرفی بهتر کسب‌وکار، مسیر اقدام کاربر و حضور حرفه‌ای آنلاین طراحی و اجرا شده‌اند.
        </p>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="section-padding bg-white">
    <div class="container-page">
      <div class="mx-auto grid max-w-5xl gap-8 sm:grid-cols-2">
        {featuredItems.map((item) => (
          <a
            href={item.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group block overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-sm transition-all duration-300 hover:border-brand-300 hover:shadow-lg hover:-translate-y-1"
          >
            <!-- Image -->
            <div class="aspect-[16/10] overflow-hidden bg-neutral-100">
              <img
                src={item.coverImage}
                alt={item.alt}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
                width="800"
                height="500"
              />
            </div>

            <!-- Content -->
            <div class="p-6">
              <div class="flex items-center gap-2">
                <span class="rounded-full bg-brand-100 px-3 py-1 text-xs font-medium text-brand-700">
                  {item.category}
                </span>
              </div>

              <h2 class="mt-3 text-xl font-bold text-neutral-800 group-hover:text-brand-600 transition-colors">
                {item.title}
              </h2>

              <p class="mt-1 text-sm text-neutral-500">{item.type}</p>

              <p class="mt-3 text-sm leading-6 text-neutral-600">
                {item.shortDescription}
              </p>

              <div class="mt-4 flex flex-wrap gap-2">
                {item.tags.map((tag) => (
                  <span class="rounded-lg bg-neutral-100 px-2.5 py-1 text-xs font-medium text-neutral-600">
                    {tag}
                  </span>
                ))}
              </div>

              <div class="mt-5 flex items-center gap-2 text-sm font-bold text-brand-600 group-hover:gap-3 transition-all">
                مشاهده سایت
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Other Projects -->
  {otherItems.length > 0 && (
    <section class="section-padding bg-surface-50">
      <div class="container-page">
        <div class="mx-auto max-w-5xl">
          <h2 class="mb-8 text-center text-xl font-bold text-neutral-800">پروژه‌های دیگر</h2>
          <div class="grid gap-6 sm:grid-cols-2">
            {otherItems.map((item) => (
              <a
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group block overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-sm transition-all duration-300 hover:border-brand-300 hover:shadow-lg hover:-translate-y-1"
              >
                <div class="aspect-[16/10] overflow-hidden bg-neutral-100">
                  <img
                    src={item.coverImage}
                    alt={item.alt}
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                    width="800"
                    height="500"
                  />
                </div>
                <div class="p-5">
                  <span class="rounded-full bg-brand-100 px-3 py-1 text-xs font-medium text-brand-700">
                    {item.category}
                  </span>
                  <h3 class="mt-2 text-lg font-bold text-neutral-800 group-hover:text-brand-600 transition-colors">
                    {item.title}
                  </h3>
                  <p class="mt-2 text-sm leading-6 text-neutral-500">
                    {item.shortDescription}
                  </p>
                  <div class="mt-3 flex flex-wrap gap-1.5">
                    {item.tags.slice(0, 3).map((tag) => (
                      <span class="rounded-lg bg-neutral-100 px-2 py-0.5 text-xs text-neutral-600">
                        {tag}
                      </span>
                    ))}
                  </div>
                  <div class="mt-4 flex items-center gap-2 text-sm font-bold text-brand-600 group-hover:gap-3 transition-all">
                    مشاهده سایت
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="section-padding bg-brand-600">
    <div class="container-page text-center">
      <h2 class="text-2xl font-bold text-white sm:text-3xl">
        می‌خواهید سایت شما هم فقط یک ویترین نباشد و به مسیر جذب مشتری تبدیل شود؟
      </h2>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/customer-acquisition-review" class="inline-flex items-center justify-center gap-2 rounded-xl bg-white px-8 py-3.5 text-base font-bold text-brand-700 shadow-lg transition-all duration-200 hover:bg-brand-50 hover:shadow-xl">
          درخواست بررسی رایگان
        </a>
        <a href="/services" class="inline-flex items-center justify-center gap-2 rounded-xl border-2 border-white/30 px-8 py-3.5 text-base font-bold text-white transition-all duration-200 hover:border-white/60 hover:bg-white/10">
          مشاهده تعرفه‌ها
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
