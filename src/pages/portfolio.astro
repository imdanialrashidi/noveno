---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CTAButton from '../components/CTAButton.astro';

const projects = [
  {
    id: 'mobilekhorsandi',
    title: 'موبایل خرسندی',
    url: 'https://mobilekhorsandi.ir/',
    coverImage: '/images/portfolio/mobilekhorsandi.ir/cover.webp',
    type: 'فروشگاه اینترنتی موبایل و لوازم جانبی',
    category: 'فروشگاه آنلاین',
    description: 'طراحی و پیاده‌سازی فروشگاه اینترنتی برای عرضه موبایل، لوازم جانبی، قطعات و گجت‌های کاربردی با مسیر خرید و دسته‌بندی محصول.',
    tags: ['فروشگاه آنلاین', 'موبایل و لوازم جانبی', 'دسته‌بندی محصول', 'مسیر خرید', 'وردپرس / فروشگاهی'],
    alt: 'نمایی از وب‌سایت فروشگاهی موبایل خرسندی',
    featured: true,
  },
  {
    id: 'elsahamrah',
    title: 'السا همراه',
    url: 'https://elsahamrah.com/',
    coverImage: '/images/portfolio/elsahamrah.com/cover.webp',
    type: 'فروشگاه اینترنتی گوشی، تبلت و ساعت هوشمند',
    category: 'فروشگاه آنلاین',
    description: 'طراحی فروشگاه اینترنتی برای فروش گوشی، تبلت، ساعت هوشمند و محصولات دیجیتال با تمرکز بر تجربه خرید ساده و قابل اعتماد.',
    tags: ['فروشگاه کالای دیجیتال', 'گوشی و تبلت', 'ساعت هوشمند', 'اعتمادسازی', 'تجربه خرید'],
    alt: 'نمایی از وب‌سایت فروشگاهی السا همراه',
    featured: true,
  },
  {
    id: 'php-ielts-house',
    title: 'خانه آیلتس PHP',
    url: 'https://phpieltshouse.ir/',
    coverImage: '/images/portfolio/phpieltshouse.ir/cover.webp',
    type: 'وب‌سایت آموزشی زبان و آیلتس',
    category: 'سایت آموزشی / خدماتی',
    description: 'طراحی سایت آموزشی برای معرفی خدمات تخصصی زبان و آیلتس در کرج با تمرکز بر ثبت‌نام، اعتمادسازی و ارتباط سریع با مخاطب.',
    tags: ['سایت آموزشی', 'آیلتس', 'زبان انگلیسی', 'ثبت‌نام', 'خدمات آموزشی'],
    alt: 'نمایی از وب‌سایت آموزشی خانه آیلتس PHP',
    featured: true,
  },
  {
    id: 'isbatab',
    title: 'ایمن صنعت باتاب',
    url: 'https://isbatab.ir/',
    coverImage: '/images/portfolio/isbatab.ir/cover.webp',
    type: 'وب‌سایت شرکتی خدمات ایمنی، آموزش و بازرسی فنی',
    category: 'سایت شرکتی / خدماتی',
    description: 'طراحی وب‌سایت شرکتی برای معرفی خدمات مشاوره، آموزش، ایمنی و بازرسی فنی با ساختار رسمی و قابل اعتماد.',
    tags: ['سایت شرکتی', 'خدمات ایمنی', 'بازرسی فنی', 'آموزش', 'اعتبارسازی'],
    alt: 'نمایی از وب‌سایت شرکتی ایمن صنعت باتاب',
    featured: true,
  },
  {
    id: 'danial-rashidi',
    title: 'وب‌سایت شخصی دانیال رشیدی',
    url: 'https://imdanialrashidi.github.io/',
    coverImage: '/images/portfolio/imdanialrashidi.github.io/cover.webp',
    type: 'وب‌سایت شخصی و معرفی مهارت‌ها',
    category: 'سایت شخصی / پرتفولیو',
    description: 'طراحی وب‌سایت شخصی برای معرفی مسیر کاری، مهارت‌ها، علاقه‌مندی‌ها و هویت حرفه‌ای در حوزه وب و سیستم‌های هوش مصنوعی.',
    tags: ['سایت شخصی', 'پرتفولیو', 'هویت حرفه‌ای', 'وب و هوش مصنوعی', 'طراحی سبک'],
    alt: 'نمایی از وب‌سایت شخصی دانیال رشیدی',
    featured: false,
  },
];

const featuredProjects = projects.filter(p => p.featured);
const otherProjects = projects.filter(p => !p.featured);

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'نمونه کارهای نوونو',
  description: 'نمونه‌هایی از وب‌سایت‌ها و سیستم‌هایی که نوونو با تمرکز بر معرفی بهتر کسب‌وکار، مسیر اقدام کاربر و حضور حرفه‌ای آنلاین طراحی و اجرا کرده است.',
  url: 'https://noveno.ir/portfolio',
};
---

<BaseLayout
  title="نمونه کارها"
  description="نمونه‌هایی از وب‌سایت‌ها و سیستم‌هایی که نوونو با تمرکز بر معرفی بهتر کسب‌وکار، مسیر اقدام کاربر و حضور حرفه‌ای آنلاین طراحی و اجرا کرده است."
  structuredData={structuredData}
>
  <!-- Hero -->
  <section class="section-padding bg-gradient-to-b from-lavender-100 to-surface-50">
    <div class="container-page">
      <Breadcrumbs items={[{ label: 'نمونه کارها' }]} />

      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-3xl font-bold text-neutral-800 sm:text-4xl text-balance">
          نمونه کارهای نوونو
        </h1>
        <p class="mt-4 text-base leading-7 text-neutral-600 sm:text-lg">
          چند نمونه از وب‌سایت‌ها و سیستم‌هایی که با تمرکز بر معرفی بهتر کسب‌وکار، مسیر اقدام کاربر و حضور حرفه‌ای آنلاین طراحی و اجرا شده‌اند.
        </p>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="section-padding bg-white">
    <div class="container-page">
      <div class="mx-auto grid max-w-6xl gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {featuredProjects.map((project) => (
          <a
            href={project.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group block rounded-2xl border border-neutral-200 bg-white shadow-sm transition-all duration-300 hover:border-brand-300 hover:shadow-lg hover:-translate-y-1 overflow-hidden"
          >
            <!-- Image -->
            <div class="relative aspect-[16/10] overflow-hidden bg-lavender-50">
              <img
                src={project.coverImage}
                alt={project.alt}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
                width="800"
                height="500"
              />
              <!-- Category badge -->
              <div class="absolute top-3 right-3">
                <span class="rounded-full bg-white/90 px-3 py-1 text-xs font-medium text-brand-700 backdrop-blur-sm shadow-sm">
                  {project.category}
                </span>
              </div>
            </div>

            <!-- Content -->
            <div class="p-5">
              <h2 class="text-lg font-bold text-neutral-800 group-hover:text-brand-600 transition-colors">
                {project.title}
              </h2>
              <p class="mt-1 text-xs text-neutral-400">{project.type}</p>
              <p class="mt-3 text-sm leading-6 text-neutral-500 line-clamp-2">
                {project.description}
              </p>

              <!-- Tags -->
              <div class="mt-4 flex flex-wrap gap-1.5">
                {project.tags.slice(0, 3).map((tag) => (
                  <span class="rounded-md bg-lavender-50 px-2 py-0.5 text-[11px] font-medium text-brand-600">
                    {tag}
                  </span>
                ))}
                {project.tags.length > 3 && (
                  <span class="rounded-md bg-neutral-100 px-2 py-0.5 text-[11px] font-medium text-neutral-500">
                    +{project.tags.length - 3}
                  </span>
                )}
              </div>

              <!-- CTA -->
              <div class="mt-4 flex items-center gap-2 text-sm font-semibold text-brand-600 group-hover:text-brand-700">
                مشاهده سایت
                <svg class="h-4 w-4 transition-transform duration-300 group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Other Projects -->
  {otherProjects.length > 0 && (
    <section class="section-padding bg-surface-50">
      <div class="container-page">
        <div class="mx-auto max-w-6xl">
          <h2 class="mb-8 text-xl font-bold text-neutral-800">سایر پروژه‌ها</h2>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {otherProjects.map((project) => (
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group block rounded-2xl border border-neutral-200 bg-white shadow-sm transition-all duration-300 hover:border-brand-300 hover:shadow-lg hover:-translate-y-1 overflow-hidden"
              >
                <div class="relative aspect-[16/10] overflow-hidden bg-lavender-50">
                  <img
                    src={project.coverImage}
                    alt={project.alt}
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                    width="800"
                    height="500"
                  />
                  <div class="absolute top-3 right-3">
                    <span class="rounded-full bg-white/90 px-3 py-1 text-xs font-medium text-brand-700 backdrop-blur-sm shadow-sm">
                      {project.category}
                    </span>
                  </div>
                </div>
                <div class="p-5">
                  <h3 class="text-lg font-bold text-neutral-800 group-hover:text-brand-600 transition-colors">
                    {project.title}
                  </h3>
                  <p class="mt-1 text-xs text-neutral-400">{project.type}</p>
                  <p class="mt-3 text-sm leading-6 text-neutral-500 line-clamp-2">
                    {project.description}
                  </p>
                  <div class="mt-4 flex flex-wrap gap-1.5">
                    {project.tags.slice(0, 3).map((tag) => (
                      <span class="rounded-md bg-lavender-50 px-2 py-0.5 text-[11px] font-medium text-brand-600">
                        {tag}
                      </span>
                    ))}
                  </div>
                  <div class="mt-4 flex items-center gap-2 text-sm font-semibold text-brand-600 group-hover:text-brand-700">
                    مشاهده سایت
                    <svg class="h-4 w-4 transition-transform duration-300 group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="section-padding bg-brand-600">
    <div class="container-page text-center">
      <h2 class="text-2xl font-bold text-white sm:text-3xl">
        می‌خواهید سایت شما هم فقط یک ویترین نباشد؟
      </h2>
      <p class="mt-3 text-base text-brand-100 sm:text-lg">
        به مسیر جذب مشتری تبدیل شود؟
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/customer-acquisition-review" class="inline-flex items-center justify-center gap-2 rounded-xl bg-white px-8 py-3.5 text-base font-bold text-brand-700 shadow-lg transition-all duration-200 hover:bg-brand-50 hover:shadow-xl focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white">
          درخواست بررسی رایگان
        </a>
        <a href="/services" class="inline-flex items-center justify-center gap-2 rounded-xl border-2 border-white/30 px-8 py-3.5 text-base font-bold text-white transition-all duration-200 hover:border-white hover:bg-white/10">
          مشاهده تعرفه‌ها
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
