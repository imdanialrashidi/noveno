---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SectionHeading from '../components/SectionHeading.astro';
import DemoLabel from '../components/DemoLabel.astro';
import CTAButton from '../components/CTAButton.astro';

const projects = [
  {
    title: 'کلینیک زیبایی نور',
    description: 'صفحه جذب مشتری با فرم مشاوره و نوبت‌دهی آنلاین. تمرکز بر معرفی خدمات تخصصی و اعتمادسازی.',
    tags: ['صفحه جذب مشتری', 'فرم مشاوره', 'نوبت‌دهی'],
    result: 'افزایش درخواست مشاوره در ماه اول',
    image: '/portfolio/clinic.jpg',
    link: '/services/customer-acquisition-page',
  },
  {
    title: 'آموزشگاه زبان پارسیان',
    description: 'سایت معرفی دوره‌ها با فرم ثبت‌نام و پیگیری متقاضیان. مسیر ساده از معرفی تا ثبت‌نام.',
    tags: ['سایت خدماتی', 'فرم ثبت‌نام', 'پیگیری'],
    result: 'کاهش ثبت‌نام‌های ناقص',
    image: '/portfolio/language-school.jpg',
    link: '/services/light-business-website',
  },
  {
    title: 'سالن زیبایی رز',
    description: 'صفحه معرفی خدمات با نوبت‌دهی آنلاین و گالری نمونه کار. تمرکز بر جذب مشتری جدید.',
    tags: ['صفحه جذب مشتری', 'نوبت‌دهی', 'گالری'],
    result: 'افزایش نوبت‌دهی آنلاین',
    image: '/portfolio/salon.jpg',
    link: '/services/customer-acquisition-page',
  },
  {
    title: 'مشاور املاک ایرانیان',
    description: 'صفحه معرفی خدمات با فرم درخواست بازدید و پیگیری مشتریان. هر لید ارزش بالایی دارد.',
    tags: ['صفحه جذب مشتری', 'فرم بازدید', 'پیگیری'],
    result: 'بهبود پیگیری لیدها',
    image: '/portfolio/real-estate.jpg',
    link: '/services/lead-management',
  },
  {
    title: 'تعمیرگاه تخصصی خودرو',
    description: 'سایت معرفی خدمات با فرم درخواست تعمیر و اطلاع‌رسانی موجودی. اعتمادسازی مهم‌ترین عامل.',
    tags: ['سایت خدماتی', 'فرم درخواست', 'اطلاع‌رسانی'],
    result: 'افزایش درخواست تعمیر',
    image: '/portfolio/repair-shop.jpg',
    link: '/services/light-business-website',
  },
  {
    title: 'فروشگاه محصولات ارگانیک',
    description: 'فروشگاه سبک با معرفی محصولات، فرم سفارش و اطلاع‌رسانی موجودی. محصولات محدود ولی با ارزش.',
    tags: ['فروشگاه سبک', 'فرم سفارش', 'موجودی'],
    result: 'افزایش سفارشات آنلاین',
    image: '/portfolio/organic-store.jpg',
    link: '/services/light-online-store',
  },
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'نمونه کارهای نوونو',
  description: 'نمونه‌هایی از پروژه‌های نوونو در زمینه سیستم جذب مشتری برای کسب‌وکارهای کوچک.',
  url: 'https://noveno.ir/portfolio',
};
---

<BaseLayout
  title="نمونه کار"
  description="نمونه‌هایی از پروژه‌های نوونو: صفحات جذب مشتری، سایت‌های خدماتی و فروشگاه‌های سبک برای کسب‌وکارهای کوچک ایرانی."
  structuredData={structuredData}
>
  <section class="section-padding bg-gradient-to-b from-lavender-100 to-surface-50">
    <div class="container-page">
      <Breadcrumbs items={[{ label: 'نمونه کار' }]} />

      <div class="mx-auto max-w-3xl text-center">
        <p class="mb-3 text-sm font-medium text-brand-600">نمونه‌های نمایشی</p>
        <h1 class="text-3xl font-bold text-neutral-800 sm:text-4xl text-balance">
          نمونه کارهای ما
        </h1>
        <p class="mt-4 text-base leading-7 text-neutral-600 sm:text-lg">
          نمونه‌های زیر بر اساس سناریوهای واقعی طراحی شده‌اند تا نحوه کار نوونو را نشان دهند.
        </p>
      </div>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-page">
      <div class="mx-auto grid max-w-5xl gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {projects.map((project) => (
          <a href={project.link} class="group rounded-2xl border border-neutral-200 bg-white shadow-sm transition-all duration-200 hover:border-brand-300 hover:shadow-md overflow-hidden">
            <div class="aspect-video bg-lavender-100 flex items-center justify-center">
              <img
                src={project.image}
                alt={project.title}
                class="w-full h-full object-cover"
                loading="lazy"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
              />
              <div class="hidden items-center justify-center w-full h-full text-brand-400">
                <svg class="h-12 w-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
            </div>
            <div class="p-6">
              <div class="flex items-center gap-2">
                <h2 class="text-lg font-semibold text-neutral-800 group-hover:text-brand-600 transition-colors">{project.title}</h2>
                <DemoLabel />
              </div>
              <p class="mt-3 text-sm leading-6 text-neutral-500">{project.description}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {project.tags.map((tag) => (
                  <span class="rounded-lg bg-lavender-100 px-2.5 py-1 text-xs font-medium text-brand-700">
                    {tag}
                  </span>
                ))}
              </div>
              <div class="mt-4 rounded-lg bg-green-50 p-3">
                <p class="text-xs font-medium text-green-700">نتیجه:</p>
                <p class="text-sm text-green-600">{project.result}</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-surface-50">
    <div class="container-page">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-2xl font-bold text-neutral-800 sm:text-3xl">
          پروژه شما بعدی اینجاست
        </h2>
        <p class="mt-3 text-base text-neutral-600">
          اگر آماده‌اید سیستم جذب مشتری خود را بسازید، همین حالا شروع کنید.
        </p>
        <div class="mt-8">
          <CTAButton href="/customer-acquisition-review" size="lg">
            درخواست بررسی مسیر جذب
          </CTAButton>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
