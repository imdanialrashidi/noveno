---
interface Props {
  question: string;
  id?: string;
}

const { question, id } = Astro.props;
const detailId = id || `faq-${Math.random().toString(36).slice(2, 8)}`;
---

<details class="group border-b border-neutral-200 py-4">
  <summary
    class="flex cursor-pointer items-center justify-between gap-4 text-right text-base font-medium text-neutral-800 hover:text-brand-600 transition-colors list-none marker:hidden
    [&::-webkit-details-marker]:hidden"
    role="button"
  >
    <span>{question}</span>
    <svg
      class="h-5 w-5 shrink-0 text-neutral-400 transition-transform duration-200 group-open:rotate-180"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </summary>
  <div class="mt-3 pr-0 text-sm leading-7 text-neutral-600">
    <slot />
  </div>
</details>
