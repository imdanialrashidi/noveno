---
interface Props {
  href: string;
  title: string;
  description: string;
  icon?: string;
}

const { href, title, description, icon = 'M13 10V3L4 14h7v7l9-11h-7z' } = Astro.props;
---

<a
  href={href}
  class="group block rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm transition-all duration-200 hover:border-brand-300 hover:shadow-md"
>
  <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-50 text-brand-600 transition-colors group-hover:bg-brand-100">
    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon} />
    </svg>
  </div>
  <h3 class="mt-4 text-lg font-semibold text-neutral-800 group-hover:text-brand-600 transition-colors">{title}</h3>
  <p class="mt-2 text-sm leading-6 text-neutral-500">{description}</p>
  <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-brand-600 group-hover:gap-2 transition-all">
    مشاهده جزئیات
    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
    </svg>
  </span>
</a>
