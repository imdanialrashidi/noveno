---
interface Props {
  step: number;
  title: string;
  description: string;
}

const { step, title, description } = Astro.props;
---

<div class="flex gap-4">
  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-brand-600 text-sm font-bold text-white">
    {step}
  </div>
  <div class="pt-1">
    <h3 class="text-base font-semibold text-neutral-800">{title}</h3>
    <p class="mt-1 text-sm leading-6 text-neutral-500">{description}</p>
  </div>
</div>
