---
interface Props {
  title: string;
  subtitle?: string;
  class?: string;
}

const { title, subtitle, class: className = '' } = Astro.props;
---

<div class={`text-center ${className}`}>
  <h2 class="text-2xl font-bold text-neutral-800 sm:text-3xl lg:text-4xl">{title}</h2>
  {subtitle && (
    <p class="mt-3 text-base text-neutral-500 sm:text-lg">{subtitle}</p>
  )}
</div>
