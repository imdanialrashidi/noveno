---
interface Props {
  name: string;
  description: string;
  icon?: string;
}

const { name, description, icon = 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' } = Astro.props;
---

<div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
  <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-lavender-200 text-brand-600">
    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon} />
    </svg>
  </div>
  <h3 class="mt-3 text-base font-semibold text-neutral-800">{name}</h3>
  <p class="mt-2 text-sm leading-6 text-neutral-500">{description}</p>
</div>
