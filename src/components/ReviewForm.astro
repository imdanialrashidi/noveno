---
---

<form
  id="review-form"
  action="https://api.web3forms.com/submit"
  method="POST"
  class="space-y-5"
>
  <input type="hidden" name="access_key" value="57f6da33-cef2-4b2b-a3de-f4b279030c53" />
  <input type="hidden" name="from_name" value="Noveno Website" />
  <input type="hidden" name="redirect" value="https://noveno.ir/thank-you?source=review" />
  <input type="hidden" name="subject" value="درخواست بررسی مسیر جذب - Noveno" />
  <input type="hidden" name="botcheck" value="" class="hidden" />
  <input type="hidden" name="form_name" value="customer_acquisition_review" />
  <input type="hidden" name="site_domain" value="noveno.ir" />

  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <label for="review-fullname" class="mb-1.5 block text-sm font-medium text-neutral-700">
        نام و نام خانوادگی <span class="text-red-500" aria-hidden="true">*</span>
      </label>
      <input
        type="text"
        id="review-fullname"
        name="full_name"
        required
        autocomplete="name"
        class="w-full rounded-xl border border-neutral-300 bg-white px-4 py-2.5 text-sm text-neutral-800 placeholder:text-neutral-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200 transition-colors"
        placeholder="نام و نام خانوادگی"
      />
    </div>

    <div>
      <label for="review-business-name" class="mb-1.5 block text-sm font-medium text-neutral-700">
        نام کسب‌وکار <span class="text-red-500" aria-hidden="true">*</span>
      </label>
      <input
        type="text"
        id="review-business-name"
        name="business_name"
        required
        class="w-full rounded-xl border border-neutral-300 bg-white px-4 py-2.5 text-sm text-neutral-800 placeholder:text-neutral-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200 transition-colors"
        placeholder="نام کسب‌وکار"
      />
    </div>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <label for="review-business-type" class="mb-1.5 block text-sm font-medium text-neutral-700">
        نوع کسب‌وکار <span class="text-red-500" aria-hidden="true">*</span>
      </label>
      <input
        type="text"
        id="review-business-type"
        name="business_type"
        required
        class="w-full rounded-xl border border-neutral-300 bg-white px-4 py-2.5 text-sm text-neutral-800 placeholder:text-neutral-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200 transition-colors"
        placeholder="مثلاً: کلینیک زیبایی، آموزشگاه زبان"
      />
    </div>

    <div>
      <label for="review-city" class="mb-1.5 block text-sm font-medium text-neutral-700">
        شهر <span class="text-red-500" aria-hidden="true">*</span>
      </label>
      <input
        type="text"
        id="review-city"
        name="city"
        required
        class="w-full rounded-xl border border-neutral-300 bg-white px-4 py-2.5 text-sm text-neutral-800 placeholder:text-neutral-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200 transition-colors"
        placeholder="شهر"
      />
    </div>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <label for="review-phone" class="mb-1.5 block text-sm font-medium text-neutral-700">
        شماره تماس <span class="text-red-500" aria-hidden="true">*</span>
      </label>
      <input
        type="tel"
        id="review-phone"
        name="phone"
        required
        autocomplete="tel"
        dir="ltr"
        class="w-full rounded-xl border border-neutral-300 bg-white px-4 py-2.5 text-sm text-neutral-800 placeholder:text-neutral-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200 transition-colors"
        placeholder="09XXXXXXXXX"
      />
    </div>

    <div>
      <label for="review-url" class="mb-1.5 block text-sm font-medium text-neutral-700">
        آدرس پیج یا سایت
      </label>
      <input
        type="url"
        id="review-url"
        name="website_or_social"
        class="w-full rounded-xl border border-neutral-300 bg-white px-4 py-2.5 text-sm text-neutral-800 placeholder:text-neutral-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200 transition-colors"
        placeholder="https://..."
        dir="ltr"
      />
    </div>
  </div>

  <div>
    <label for="review-main-problem" class="mb-1.5 block text-sm font-medium text-neutral-700">
      مهم‌ترین مشکل فعلی در جذب مشتری <span class="text-red-500" aria-hidden="true">*</span>
    </label>
    <textarea
      id="review-main-problem"
      name="main_customer_acquisition_problem"
      required
      rows="3"
      class="w-full rounded-xl border border-neutral-300 bg-white px-4 py-2.5 text-sm text-neutral-800 placeholder:text-neutral-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200 transition-colors resize-none"
      placeholder="مهم‌ترین مشکلی که در جذب مشتری دارید چیست؟"
    ></textarea>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <label for="review-ads" class="mb-1.5 block text-sm font-medium text-neutral-700">
        آیا تبلیغات انجام می‌دهید؟
      </label>
      <select
        id="review-ads"
        name="running_ads"
        class="w-full rounded-xl border border-neutral-300 bg-white px-4 py-2.5 text-sm text-neutral-800 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200 transition-colors"
      >
        <option value="">انتخاب کنید</option>
        <option value="بله">بله</option>
        <option value="خیر">خیر</option>
        <option value="گاهی">گاهی</option>
      </select>
    </div>

    <div>
      <label for="review-source" class="mb-1.5 block text-sm font-medium text-neutral-700">
        مشتری‌ها بیشتر از کجا می‌آیند؟
      </label>
      <input
        type="text"
        id="review-source"
        name="lead_sources"
        class="w-full rounded-xl border border-neutral-300 bg-white px-4 py-2.5 text-sm text-neutral-800 placeholder:text-neutral-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200 transition-colors"
        placeholder="مثلاً: اینستاگرام، معرفی دوستان"
      />
    </div>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <label for="review-leads" class="mb-1.5 block text-sm font-medium text-neutral-700">
        آیا لیدها جایی ثبت می‌شوند؟
      </label>
      <select
        id="review-leads"
        name="lead_tracking_status"
        class="w-full rounded-xl border border-neutral-300 bg-white px-4 py-2.5 text-sm text-neutral-800 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200 transition-colors"
      >
        <option value="">انتخاب کنید</option>
        <option value="بله، در فایل یا نرم‌افزار">بله، در فایل یا نرم‌افزار</option>
        <option value="خیر، ثبت نمی‌شود">خیر، ثبت نمی‌شود</option>
        <option value="بخشی ثبت می‌شود">بخشی ثبت می‌شود</option>
      </select>
    </div>

    <div>
      <label for="review-contact-method" class="mb-1.5 block text-sm font-medium text-neutral-700">
        روش ترجیحی تماس
      </label>
      <select
        id="review-contact-method"
        name="preferred_contact_method"
        class="w-full rounded-xl border border-neutral-300 bg-white px-4 py-2.5 text-sm text-neutral-800 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200 transition-colors"
      >
        <option value="">انتخاب کنید</option>
        <option value="تماس تلفنی">تماس تلفنی</option>
        <option value="واتساپ">واتساپ</option>
        <option value="فرم سایت">فرم سایت</option>
      </select>
    </div>
  </div>

  <div>
    <label for="review-extra" class="mb-1.5 block text-sm font-medium text-neutral-700">
      توضیح اختیاری
    </label>
    <textarea
      id="review-extra"
      name="extra_notes"
      rows="3"
      class="w-full rounded-xl border border-neutral-300 bg-white px-4 py-2.5 text-sm text-neutral-800 placeholder:text-neutral-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200 transition-colors resize-none"
      placeholder="هر توضیح دیگری که فکر می‌کنید مفید است..."
    ></textarea>
  </div>

  <div>
    <button
      type="submit"
      class="w-full rounded-xl bg-brand-600 px-5 py-3 text-base font-medium text-white transition-colors hover:bg-brand-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-600 disabled:opacity-50"
    >
      ارسال درخواست بررسی
    </button>
  </div>

  <p class="text-xs text-neutral-400 text-center">
    این فرم برای بررسی مسیر جذب مشتری شماست و به معنای فروش تضمینی نیست. خروجی بررسی یک پیشنهاد عملی برای بهبود مسیر جذب خواهد بود.
  </p>

  <p class="text-xs text-neutral-400 text-center">
    اطلاعات شما فقط برای بررسی درخواست و تماس با شما استفاده می‌شود.
  </p>
</form>
